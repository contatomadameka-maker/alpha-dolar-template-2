    <!-- ============================================================
         🔥 SISTEMA DE REGISTROS — Feed colorido igual ao DC Bot
    ============================================================ -->
    <script>
    (() => {
        const feed = document.getElementById('registros-feed');
        const tradesHistoricoBody = document.getElementById('tradesHistoricoBody');
        let registros = [];

        // -------- TOAST --------
        function mostrarToast(mensagem, tipo = 'info') {
            const toast = document.createElement('div');
            toast.className = `toast ${tipo}`;
            toast.innerText = mensagem;
            document.body.appendChild(toast);
            setTimeout(() => toast.classList.add('show'), 50);
            setTimeout(() => {
                toast.classList.remove('show');
                setTimeout(() => toast.remove(), 300);
            }, 3500);
        }

        // -------- ADICIONAR LINHA NO FEED --------
        function addLogLine(texto, cssClass) {
            const agora = new Date();
            const hora = agora.toTimeString().slice(0, 8);

            const entry = document.createElement('div');
            entry.className = 'log-entry';
            entry.innerHTML = `<span class="log-time">${hora}</span><span class="${cssClass}">${texto}</span>`;
            feed.appendChild(entry);

            // Auto-scroll para o final
            feed.scrollTop = feed.scrollHeight;

            // Guarda no array
            registros.push({ hora, texto, cssClass });
        }

        // -------- API PÚBLICA — chamada pelo controlador do bot --------
        window.registrarEvento = function(mensagem, tipo = 'init') {
            const mapa = {
                init:     'log-init',
                analysis: 'log-analysis',
                action:   'log-action',
                win:      'log-win',
                loss:     'log-loss',
                alert:    'log-alert',
                virtual:  'log-virtual',
            };
            const cssClass = mapa[tipo] || 'log-init';
            addLogLine(mensagem, cssClass);

            // Toast para vitória e derrota
            if (tipo === 'win')  mostrarToast(mensagem, 'ganho');
            if (tipo === 'loss') mostrarToast(mensagem, 'perda');
            if (tipo === 'alert') mostrarToast(mensagem, 'info');
        };

        window.registrarTrade = function({ tipo, mercado, valor, duracao, resultado, lucro }) {
            const isWin = resultado === 'WIN' || lucro > 0;
            const lucroNum = parseFloat(lucro) || 0;

            // Log no feed
            const textoLog = isWin
                ? `Ganho $${Math.abs(lucroNum).toFixed(2)} ${tipo} | ${mercado} | Tique de saída`
                : `Perda $${Math.abs(lucroNum).toFixed(2)} ${tipo} | ${mercado} | Tique de saída`;

            addLogLine(textoLog, isWin ? 'log-win' : 'log-loss');

            // Toast
            mostrarToast(
                isWin ? `✅ Vitória $${Math.abs(lucroNum).toFixed(2)} ${tipo} | ${mercado}` : `❌ Perda $${Math.abs(lucroNum).toFixed(2)} ${tipo} | ${mercado}`,
                isWin ? 'ganho' : 'perda'
            );

            // Tabela de histórico na aba Negociações
            const agora = new Date();
            const tr = document.createElement('tr');
            tr.innerHTML = `
                <td>${agora.toTimeString().slice(0,8)}</td>
                <td>${tipo || '—'}</td>
                <td>${mercado || '—'}</td>
                <td>$${parseFloat(valor || 0).toFixed(2)}</td>
                <td class="${isWin ? 'td-win' : 'td-loss'}">${isWin ? 'WIN' : 'LOSS'}</td>
                <td class="${isWin ? 'td-win' : 'td-loss'}">${lucroNum >= 0 ? '+' : ''}$${lucroNum.toFixed(2)}</td>
            `;
            if (tradesHistoricoBody) {
                tradesHistoricoBody.insertBefore(tr, tradesHistoricoBody.firstChild);
            }
        };

        window.limparRegistros = function() {
            if (!confirm('Deseja limpar o log de registros?')) return;
            registros = [];
            feed.innerHTML = '';
            mostrarToast('🗑️ Registros limpos', 'info');
        };

    })();
    </script>

    <!-- 🔥 FUNÇÃO GLOBAL DE SALDO — disponível para todos os blocos -->
    <script>
    function atualizarSaldoNaTela(saldo) {
        const formatado      = '$ ' + parseFloat(saldo).toFixed(2);
        const formatadoModal = '$' + parseFloat(saldo).toFixed(2);
        const topBalance = document.getElementById('topBalance');
        const modalSaldo = document.getElementById('botRunningSaldo');
        if (topBalance) topBalance.innerText = formatado;
        if (modalSaldo) modalSaldo.innerText  = formatadoModal;
    }
    </script>

    <!-- ============================================================
         🔥 CONTROLE DO BOT — BUG DO CATCH CORRIGIDO + SALDO FUNCIONAL
    ============================================================ -->
    <script>
    (() => {
        const API_BASE = 'https://alpha-dolar-backend.onrender.com/api';

        let botRunning      = false;
        let statusInterval  = null;
        let saldoInicial    = 0;
        let lucroAcumulado  = 0;
        let totalTrades     = 0;
        let primeiraOperacao = true;
        let ultimoTradeProcessado = 0;

        const startButton      = document.getElementById('startButton');
        const stopBotBtn       = document.getElementById('stopBotBtn');
        const modal            = document.getElementById('botRunningModal');
        const statusText       = document.getElementById('botStatusText');
        const statusMessage    = document.getElementById('botStatusMessage');
        const connectionStatus = document.getElementById('connectionStatus');
        const progressSegments = document.getElementById('progressSegments');

        // -------- BARRA DE LOADING --------
        function atualizarBarraLoading(nivel) {
            const segments = progressSegments.querySelectorAll('.progress-segment');
            segments.forEach((seg, idx) => {
                seg.classList.remove('active', 'loading');
                if (idx < nivel) seg.classList.add('active');
                if (idx === nivel - 1 && nivel > 0) seg.classList.add('loading');
            });
        }

        const MENSAGENS = {
            iniciando:       { texto: 'Iniciando robô...',               spinner: true,  barra: 1 },
            conectando:      { texto: 'Conectando à Deriv...',           spinner: true,  barra: 1 },
            conectado:       { texto: 'Conectado! Analisando mercado...', spinner: true, barra: 2 },
            buscando:        { texto: 'Buscando oportunidades...',        spinner: true,  barra: 2 },
            primeiraOperacao:{ texto: 'Aguardando primeira operação...',  spinner: true,  barra: 2 },
            proximaOperacao: { texto: 'Aguardando próxima operação...',   spinner: false, barra: 3 },
            operando:        { texto: 'Trade em andamento...',            spinner: false, barra: 3 },
        };

        function atualizarMensagem(tipo, customText = null) {
            const msg = MENSAGENS[tipo];
            if (!msg) return;
            statusText.innerText = customText || msg.texto;
            const spinnerEl = statusMessage.querySelector('.spinner');
            if (spinnerEl) spinnerEl.style.display = msg.spinner ? 'block' : 'none';
            atualizarBarraLoading(msg.barra);
        }

        // -------- 🔥 FUNÇÃO CENTRAL DE ATUALIZAÇÃO DO SALDO --------
        // Atualiza TODOS os elementos de saldo na tela de uma vez
        function atualizarSaldoNaTela(saldo) {
            const formatado = `$ ${parseFloat(saldo).toFixed(2)}`;
            const formatadoModal = `$${parseFloat(saldo).toFixed(2)}`;

            const topBalance   = document.getElementById('topBalance');
            const modalSaldo   = document.getElementById('botRunningSaldo');

            if (topBalance) topBalance.innerText = formatado;
            if (modalSaldo) modalSaldo.innerText  = formatadoModal;
        }

        // -------- HEALTH CHECK --------
        async function healthCheck() {
            try {
                const res = await fetch(API_BASE + '/health');
                if (!res.ok) throw new Error();
                connectionStatus.style.backgroundColor = '#4caf50';
                connectionStatus.title = 'Conectado';
                return true;
            } catch {
                connectionStatus.style.backgroundColor = '#f44336';
                connectionStatus.title = 'Servidor Offline';
                return false;
            }
        }

        // -------- 🔥 BUSCAR SALDO — lê do localStorage (Deriv via WebSocket) --------
        async function buscarSaldo(tipo = null) {
            try {
                // Usa tipo passado ou tipo ativo do localStorage
                const tipoAtivo = tipo || localStorage.getItem('deriv_conta_ativa') || 'demo';
                const saved = localStorage.getItem('deriv_balance_' + tipoAtivo);
                const saldo = parseFloat(saved) || 0;
                if (saldo > 0) atualizarSaldoNaTela(saldo);
                return saldo;
            } catch (err) {
                console.warn('⚠️ Não foi possível buscar saldo:', err.message);
                return 0;
            }
        }

        // -------- START BOT --------
        async function startBot() {
            const payload = {
                bot_type: 'ia',
                config: {
                    stake_inicial: parseFloat(document.getElementById('initialStake')?.value || 0.35),
                    lucro_alvo:    parseFloat(document.getElementById('targetProfit')?.value || 2.0),
                    limite_perda:  parseFloat(document.getElementById('stopLoss')?.value    || 5.0),
                    symbol:        document.getElementById('selectedMarket')?.innerText || 'R_100'
                }
            };

            const res = await fetch(API_BASE + '/bot/start', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
            });

            const data = await res.json();
            if (!res.ok || !data.success) throw new Error(data.error || 'Falha ao iniciar bot');
        }

        // -------- STOP BOT --------
        async function stopBot() {
            try {
                await fetch(API_BASE + '/bot/stop', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ bot_type: 'ia' })
                });
            } catch (err) {
                console.warn('⚠️ Erro ao parar bot:', err.message);
            }
        }

        // -------- 🔥 BUSCAR TRADES (BUG DO CATCH CORRIGIDO) --------
        async function buscarTradesDoBackend() {
            // ✅ CORREÇÃO: era um try/catch dentro de outro try/catch
            // na mesma função, causando SyntaxError silencioso.
            // Agora é um único bloco try/catch limpo.
            try {
                const res = await fetch(API_BASE + '/bot/trades/ia');
                if (!res.ok) return;

                const data = await res.json();
                if (!data.success) return;

                const tradesList = data.trades || data.data || data.results || [];
                if (!Array.isArray(tradesList)) return;

                for (const trade of tradesList) {
                    const tradeId = trade.id || trade.trade_id || trade.contract_id || 0;
                    if (tradeId <= ultimoTradeProcessado) continue;

                    ultimoTradeProcessado = Math.max(ultimoTradeProcessado, tradeId);

                    const lucroTrade = parseFloat(trade.profit || trade.lucro || trade.payout || trade.profit_loss || 0);
                    const stakeTrade = parseFloat(trade.stake || trade.valor || trade.amount || 1);

                    let resultado = 'LOSS';
                    if (trade.result) {
                        resultado = (trade.result === 'win' || trade.result === 'WIN') ? 'WIN' : 'LOSS';
                    } else if (trade.resultado) {
                        resultado = trade.resultado;
                    } else {
                        resultado = lucroTrade > 0 ? 'WIN' : 'LOSS';
                    }

                    window.registrarTrade({
                        tipo:      trade.direction || trade.tipo || trade.contract_type || 'Digit Under',
                        mercado:   trade.market || trade.mercado || trade.symbol || 'Volatility 100',
                        valor:     stakeTrade,
                        duracao:   trade.duration || trade.duracao || '1 tick',
                        resultado: resultado,
                        lucro:     lucroTrade
                    });
                }
            } catch (err) {
                // Silencioso — não interrompe o fluxo
                console.warn('⚠️ buscarTradesDoBackend:', err.message);
            }
        }

        // -------- ATUALIZAR STATUS DO BOT --------
        async function atualizarStatusBot() {
            try {
                const res = await fetch(API_BASE + '/bot/stats/ia');
                if (!res.ok) return;

                const data = await res.json();
                if (!data.success) return;

                // 🔥 Saldo: usa localStorage se backend não retornar
                const saldoBackend = parseFloat(data.balance || data.saldo_atual || 0);
                const tipoAtivo = localStorage.getItem('deriv_conta_ativa') || 'demo';
                const saldoLocal = parseFloat(localStorage.getItem('deriv_balance_' + tipoAtivo)) || 0;
                const saldoAtual = saldoBackend > 0 ? saldoBackend : saldoLocal;
                if (saldoAtual > 0) atualizarSaldoNaTela(saldoAtual);

                // Lucro — só atualiza se saldo realmente mudou do inicial
                const lucroLiquido  = (saldoInicial > 0 && saldoAtual > 0 && Math.abs(saldoAtual - saldoInicial) > 0.001)
                    ? (saldoAtual - saldoInicial) : lucroAcumulado;
                const profitPercent = saldoInicial > 0 ? ((lucroLiquido / saldoInicial) * 100) : 0;
                lucroAcumulado = lucroLiquido;

                const profitEl      = document.getElementById('botRunningProfit');
                const sessionProfit = document.getElementById('sessionProfit');
                const lucroTexto    = `$${lucroLiquido.toFixed(2)} (${profitPercent.toFixed(1)}%)`;

                if (profitEl)      profitEl.innerText      = lucroTexto;
                if (sessionProfit) sessionProfit.innerText = lucroTexto;

                const cor = lucroLiquido > 0 ? '#4caf50' : lucroLiquido < 0 ? '#f44336' : '#888';
                if (profitEl)      profitEl.style.color      = cor;
                if (sessionProfit) sessionProfit.style.color = cor;

                // Mensagem de status
                const tradesAtuais = data.total_trades || 0;
                const winRate      = data.win_rate || 0;

                if (data.status === 'starting') {
                    atualizarMensagem('conectando');
                } else if (tradesAtuais === 0) {
                    atualizarMensagem(primeiraOperacao ? 'primeiraOperacao' : 'buscando');
                } else {
                    primeiraOperacao = false;
                    if (tradesAtuais > totalTrades) {
                        totalTrades = tradesAtuais;
                        atualizarMensagem('operando', `Trade #${tradesAtuais} | Win: ${winRate.toFixed(1)}%`);
                    } else {
                        atualizarMensagem('proximaOperacao', `Trades: ${tradesAtuais} | Win: ${winRate.toFixed(1)}%`);
                    }
                }

                await buscarTradesDoBackend();

            } catch (err) {
                console.warn('⚠️ atualizarStatusBot:', err.message);
            }
        }

        // -------- RESETAR ESTADO --------
        function resetarEstado() {
            botRunning            = false;
            saldoInicial          = 0;
            lucroAcumulado        = 0;
            totalTrades           = 0;
            primeiraOperacao      = true;
            ultimoTradeProcessado = 0;
        }

        // -------- BOTÃO INICIAR --------
        startButton?.addEventListener('click', async (e) => {
            e.preventDefault();

            if (!(await healthCheck())) {
                alert('⚠️ Servidor offline! Verifique se o backend está rodando.');
                return;
            }

            if (!botRunning) {
                try {
                    resetarEstado();

                    window.registrarEvento('Iniciando uma nova sessão', 'init');

                    saldoInicial = await buscarSaldo();
                    atualizarSaldoNaTela(saldoInicial);

                    document.getElementById('botRunningProfit').innerText = '$0.00 (0.0%)';
                    document.getElementById('sessionProfit').innerText    = '$0.00 (0.0%)';

                    atualizarMensagem('iniciando');
                    modal.classList.add('active');

                    await startBot();

                    botRunning = true;
                    startButton.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M6 6h12v12H6z"/></svg><span>Parar Robô</span>';

                    // Sequência de logs igual ao DC Bot
                    window.registrarEvento('Começando a análise', 'analysis');

                    setTimeout(() => {
                        atualizarMensagem('conectado');
                        window.registrarEvento('Analisando Mercado..', 'analysis');
                    }, 2000);

                    setTimeout(() => {
                        atualizarMensagem('primeiraOperacao');
                        window.registrarEvento('Análise Finalizada', 'analysis');
                        window.registrarEvento('Preparando para buscar trades', 'action');
                    }, 4000);

                    setTimeout(atualizarStatusBot, 5000);
                    statusInterval = setInterval(atualizarStatusBot, 3000);

                } catch (err) {
                    if (err.message?.includes('já está rodando')) {
                        console.warn('Bot já rodando');
                        botRunning = true;
                        startButton.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M6 6h12v12H6z"/></svg><span>Parar Robô</span>';
                        if (!statusInterval) statusInterval = setInterval(atualizarStatusBot, 3000);
                    } else {
                        alert('❌ Erro: ' + err.message);
                        modal.classList.remove('active');
                        startButton.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M8 5v14l11-7z"/></svg><span>Iniciar Robô</span>';
                        resetarEstado();
                    }
                }
            } else {
                // Parar
                atualizarMensagem('iniciando', 'Parando robô...');
                if (statusInterval) { clearInterval(statusInterval); statusInterval = null; }
                await stopBot();
                window.registrarEvento(`Negociação finalizada — Lucro total: $${lucroAcumulado.toFixed(2)}`, 'init');
                modal.classList.remove('active');
                startButton.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M8 5v14l11-7z"/></svg><span>Iniciar Robô</span>';
                resetarEstado();
                await buscarSaldo(); // Atualiza saldo após parar
            }
        });

        // -------- BOTÃO PARAR NO MODAL --------
        stopBotBtn?.addEventListener('click', async () => {
            if (!botRunning) return;
            atualizarMensagem('iniciando', 'Parando robô...');
            if (statusInterval) { clearInterval(statusInterval); statusInterval = null; }
            await stopBot();
            window.registrarEvento(`Negociação finalizada — Lucro total: $${lucroAcumulado.toFixed(2)}`, 'init');
            modal.classList.remove('active');
            startButton.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24"><path fill="currentColor" d="M8 5v14l11-7z"/></svg><span>Iniciar Robô</span>';
            resetarEstado();
            await buscarSaldo();
        });

        window.stopBotFromModal = () => stopBotBtn?.click();

        // 🔥 Busca saldo ao carregar a página
        window.addEventListener('load', () => {
            healthCheck();
            buscarSaldo();
        });
    })();
    </script>

    <!-- ============================================================
         🔥 CONTROLE DE CONTA DEMO / REAL — lê do localStorage (OAuth)
    ============================================================ -->
    <script>
    (() => {
        const APP_ID = '128988';
        let currentAccountType = localStorage.getItem('deriv_conta_ativa') || 'demo';
        let wsBalance = null;

        const demoBtn      = document.getElementById('demoBtnSwitch');
        const realBtn      = document.getElementById('realBtnSwitch');
        const accountLabel = document.getElementById('accountLabel');

        // Verifica autenticação — redireciona se não logado
        function getContas() {
            try {
                const raw = localStorage.getItem('deriv_accounts');
                if (!raw) { window.location.href = 'login.html'; return null; }
                return JSON.parse(raw);
            } catch { window.location.href = 'login.html'; return null; }
        }

        // Busca saldo via WebSocket Deriv (tempo real)
        function conectarSaldo(token) {
            if (wsBalance) { try { wsBalance.close(); } catch {} }
            wsBalance = new WebSocket(`wss://ws.derivws.com/websockets/v3?app_id=${APP_ID}`);
            wsBalance.onopen = () => wsBalance.send(JSON.stringify({ authorize: token }));
            wsBalance.onmessage = e => {
                const d = JSON.parse(e.data);
                if (d.msg_type === 'authorize' && !d.error) {
                    atualizarSaldoNaTela(parseFloat(d.authorize.balance));
                    localStorage.setItem('deriv_balance_' + currentAccountType, d.authorize.balance);
                    wsBalance.send(JSON.stringify({ balance: 1, subscribe: 1 }));
                }
                if (d.msg_type === 'balance' && !d.error) {
                    atualizarSaldoNaTela(parseFloat(d.balance.balance));
                }
            };
            wsBalance.onerror = () => {
                const saved = localStorage.getItem('deriv_balance_' + currentAccountType);
                if (saved) atualizarSaldoNaTela(parseFloat(saved));
            };
        }

        function atualizarUI() {
            const contas = getContas();
            if (!contas) return;
            const querDemo = currentAccountType === 'demo';
            const conta = contas.find(c => Boolean(c.isDemo) === querDemo) || contas[0];
            if (!conta) return;
            if (accountLabel) accountLabel.innerText = currentAccountType === 'demo' ? 'Conta Demo' : 'Conta Real';
            demoBtn?.classList.toggle('active', currentAccountType === 'demo');
            realBtn?.classList.toggle('active', currentAccountType === 'real');
            // Mostra saldo salvo imediatamente
            const saved = localStorage.getItem('deriv_balance_' + currentAccountType);
            if (saved) atualizarSaldoNaTela(parseFloat(saved));
            // Depois conecta WebSocket para tempo real
            conectarSaldo(conta.token);
        }

        window.switchAccountType = function(type) {
            if (type === currentAccountType) return;
            currentAccountType = type;
            localStorage.setItem('deriv_conta_ativa', type);
            atualizarUI();
        };

        window.fazerLogout = function() {
            if (!confirm('Deseja sair da sua conta?')) return;
            ['deriv_accounts','deriv_conta_ativa','deriv_token_demo','deriv_token_real','deriv_balance_demo','deriv_balance_real'].forEach(k => localStorage.removeItem(k));
            window.location.href = 'login.html';
        };

        window.addEventListener('load', atualizarUI);
    })();
    </script>

    <!-- ============================================================
         NAVEGAÇÃO ENTRE ABAS — SUB-ABA NEGOCIAÇÕES
    ============================================================ -->
    <script>
    function switchNegTab(tab, btn) {
        document.querySelectorAll('.neg-sub-tab').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.neg-sub-content').forEach(c => c.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('neg-' + tab)?.classList.add('active');
    }
    </script>


    <!-- 🔥 OVERRIDE ESTRATÉGIAS — garante layout novo independente do modals.js -->
    <script>
    const BADGE_STYLES_NEW = {
        'FREE':    'background:transparent;color:#42A5F5;border:1.5px solid #42A5F5;padding:2px 10px;border-radius:20px;font-size:11px;font-weight:700;',
        'VIP':     'background:transparent;color:#4caf50;border:1.5px solid #4caf50;padding:2px 10px;border-radius:20px;font-size:11px;font-weight:700;',
        'PREMIUM': 'background:transparent;color:#FFB300;border:1.5px solid #FFB300;padding:2px 10px;border-radius:20px;font-size:11px;font-weight:700;',
        'NOVO':    'background:#42A5F5;color:#fff;border:none;padding:2px 10px;border-radius:20px;font-size:11px;font-weight:700;',
        'TOP':     'background:#FFB300;color:#000;border:none;padding:2px 10px;border-radius:20px;font-size:11px;font-weight:700;'
    };

    function renderStrategies(strategies, containerId) {
        const container = document.getElementById(containerId);
        if (!container || !strategies) return;
        container.innerHTML = '';
        strategies.forEach(strategy => {
            const item = document.createElement('div');
            const badges = (strategy.badges || []).map(b =>
                `<span style="${BADGE_STYLES_NEW[b] || BADGE_STYLES_NEW['FREE']}">${b}</span>`
            ).join(' ');
            const lock = strategy.locked
                ? `<svg width="14" height="14" viewBox="0 0 24 24" fill="#555"><path d="M18 8h-1V6c0-2.76-2.24-5-5-5S7 3.24 7 6v2H6c-1.1 0-2 .9-2 2v10c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V10c0-1.1-.9-2-2-2zm-6 9c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2zm3.1-9H8.9V6c0-1.71 1.39-3.1 3.1-3.1 1.71 0 3.1 1.39 3.1 3.1v2z"/></svg>`
                : '';
            const icon = strategy.icon && strategy.icon.startsWith('<svg') ? strategy.icon
                : `<svg width="24" height="24" viewBox="0 0 24 24" fill="none"><rect x="7" y="10" width="10" height="8" rx="2" fill="#42A5F5"/><circle cx="10" cy="13" r="1" fill="white"/><circle cx="14" cy="13" r="1" fill="white"/><rect x="9" y="15" width="6" height="1" rx="0.5" fill="white"/><rect x="11" y="6" width="2" height="4" fill="#42A5F5"/><circle cx="12" cy="5" r="1.5" fill="#42A5F5"/></svg>`;

            item.style.cssText = `display:flex;align-items:center;padding:10px 16px;border-bottom:1px solid #1a1d24;cursor:${strategy.locked ? 'not-allowed' : 'pointer'};transition:background 0.15s;${strategy.active ? 'background:#0d1f35;border-left:3px solid #42A5F5;' : 'border-left:3px solid transparent;'}`;
            item.innerHTML = `
                <div style="width:36px;height:36px;display:flex;align-items:center;justify-content:center;flex-shrink:0;opacity:${strategy.locked ? '0.4' : '1'}">${icon}</div>
                <div style="flex:1;padding:0 12px;"><div style="font-size:13px;font-weight:600;color:${strategy.locked ? '#666' : '#e0e0e0'};">${strategy.name}</div></div>
                <div style="display:flex;align-items:center;gap:5px;">${badges}${lock}</div>
            `;
            if (!strategy.locked) {
                item.onmouseenter = () => { if (!strategy.active) item.style.background = '#1a1d24'; };
                item.onmouseleave = () => { if (!strategy.active) item.style.background = ''; };
                item.onclick = () => {
                    const nameEl = document.getElementById('selectedStrategy');
                    if (nameEl) nameEl.textContent = strategy.name;
                    if (typeof window.selectStrategyGlobal === 'function') window.selectStrategyGlobal(strategy);
                    document.getElementById('strategyModal')?.classList.remove('active');
                };
            }
            container.appendChild(item);
        });
    }

    // Carrega e renderiza ao abrir o modal
    async function reloadStrategies() {
        try {
            const r = await fetch('data/strategies.json?v=' + Date.now());
            const d = await r.json();
            renderStrategies(d.free, 'freeStrategies');
            renderStrategies(d.vip, 'vipStrategies');
            renderStrategies(d.premium, 'premiumStrategies');
        } catch(e) { console.warn('Erro ao carregar estratégias:', e); }
    }

    // Sobrescreve a função original de abrir modal de estratégia
    const _origOpenStrategy = window.openStrategyModal;
    window.openStrategyModal = function() {
        document.getElementById('strategyModal')?.classList.add('active');
        reloadStrategies();
    };

    document.addEventListener('DOMContentLoaded', reloadStrategies);
    </script>





    <!-- 🔥 OVERRIDE MERCADOS — ícones únicos por mercado igual DC Bot -->
    <script>
    // Gera candlestick SVG único baseado em seed (market id)
    function seededRandom(seed) {
        let s = seed;
        return function() {
            s = (s * 1664525 + 1013904223) & 0xffffffff;
            return (s >>> 0) / 0xffffffff;
        };
    }

    function getCandlestickIcon(market) {
        const iconName = market.icon || '';
        const id       = market.id   || market.name || '';

        // Número do índice ex: R_10 → "10", jump_100 → "100"
        const numMatch = id.match(/(\d+)/);
        let label = numMatch ? numMatch[1] : '';
        // Para forex/crypto/commodities usa prefixo curto
        if (iconName === 'forex')           label = 'fx';
        if (iconName === 'crypto')          label = id.includes('BTC') ? 'btc' : id.includes('ETH') ? 'eth' : 'cry';
        if (iconName === 'gold')            label = 'gold';
        if (iconName === 'silver')          label = 'slvr';
        if (iconName === 'oil')             label = 'oil';
        if (iconName === 'bear-market')     label = 'bear';
        if (iconName === 'bull-market')     label = 'bull';

        const is1s = iconName.includes('1s') || id.includes('1HZ');

        // Cor por tipo
        let color  = '#42A5F5'; // azul default
        let color2 = '#1565C0'; // tom escuro para velas baixistas
        if (iconName.includes('jump')) { color = '#ff9800'; color2 = '#e65100'; }
        if (iconName === 'bear-market') { color = '#f44336'; color2 = '#b71c1c'; }
        if (iconName === 'bull-market') { color = '#4caf50'; color2 = '#1b5e20'; }
        if (iconName === 'forex')       { color = '#42A5F5'; color2 = '#1565C0'; }
        if (iconName === 'crypto')      { color = '#ff9800'; color2 = '#e65100'; }
        if (iconName === 'gold')        { color = '#ffd700'; color2 = '#f57f17'; }
        if (iconName === 'silver')      { color = '#bdbdbd'; color2 = '#616161'; }
        if (iconName === 'oil')         { color = '#90a4ae'; color2 = '#455a64'; }

        // Gera 5 velas únicas baseadas no id do mercado
        const rand = seededRandom(id.split('').reduce((a,c) => a + c.charCodeAt(0), 0));
        const totalW = 44;
        const bars = [];
        for (let i = 0; i < 5; i++) {
            const h     = 6 + Math.floor(rand() * 14);   // altura da vela 6-20
            const wick  = 2 + Math.floor(rand() * 4);    // pavio 2-6
            const up    = rand() > 0.4;                  // maioria alta (bullish)
            bars.push({ h, wick, up });
        }

        // Posições X das 5 velas
        const xs = [5, 12, 19, 26, 33];
        const baseY = 34;
        let svgBars = '';
        bars.forEach((b, i) => {
            const x   = xs[i];
            const top = baseY - b.h;
            const clr = b.up ? color : color2;
            // Pavio
            svgBars += `<line x1="${x+2}" y1="${top - b.wick}" x2="${x+2}" y2="${baseY + 2}" stroke="${clr}" stroke-width="1"/>`;
            // Corpo
            svgBars += `<rect x="${x}" y="${top}" width="4" height="${b.h}" fill="${clr}" rx="0.5"/>`;
        });

        const labelSize = label.length > 3 ? 7 : label.length > 2 ? 8 : 9;

        return `<svg width="44" height="40" viewBox="0 0 44 40">
            <text x="1" y="10" font-size="${labelSize}" font-weight="700" fill="${color}" font-family="Arial,sans-serif">${label}</text>
            ${is1s ? `<rect x="26" y="1" width="16" height="9" rx="2" fill="#f44336"/>
            <text x="28" y="9" font-size="7" font-weight="700" fill="white" font-family="Arial,sans-serif">1s</text>` : ''}
            ${svgBars}
        </svg>`;
    }

    function renderMarkets(markets, containerId) {
        const container = document.getElementById(containerId);
        if (!container || !markets) return;
        container.innerHTML = '';
        markets.forEach(market => {
            const item = document.createElement('div');
            item.style.cssText = 'display:flex;align-items:center;padding:10px 14px;border-bottom:1px solid #1a1d24;cursor:pointer;transition:background 0.15s;';
            item.innerHTML = `
                <div style="width:44px;height:40px;flex-shrink:0;">
                    ${getCandlestickIcon(market)}
                </div>
                <div style="flex:1;padding:0 10px;min-width:0;">
                    <div style="font-size:13px;font-weight:600;color:#e0e0e0;">${market.name}</div>
                    ${market.description ? `<div style="font-size:11px;color:#42A5F5;margin-top:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${market.description}</div>` : ''}
                </div>
                ${market.badge ? `<span style="background:transparent;color:#42A5F5;border:1.5px solid #42A5F5;padding:2px 8px;border-radius:20px;font-size:10px;font-weight:700;flex-shrink:0;">${market.badge}</span>` : ''}
            `;
            item.onmouseenter = () => item.style.background = '#1a1d24';
            item.onmouseleave = () => item.style.background = '';
            item.onclick = () => {
                const nameEl = document.getElementById('selectedMarket');
                const hintEl = document.getElementById('marketHint');
                if (nameEl) nameEl.textContent = market.name;
                if (hintEl && market.description) hintEl.textContent = market.description;
                if (typeof window.selectMarketGlobal === 'function') window.selectMarketGlobal(market);
                document.getElementById('marketModal')?.classList.remove('active');
            };
            container.appendChild(item);
        });
    }

    async function reloadMarkets() {
        try {
            const r = await fetch('data/markets.json?v=' + Date.now());
            const d = await r.json();
            renderMarkets(d.continuous,  'continuousMarkets');
            renderMarkets(d.dailyReset,  'dailyResetMarkets');
            renderMarkets(d.jump,        'jumpMarkets');
            renderMarkets(d.forex,       'forexMarkets');
            renderMarkets(d.crypto,      'cryptoMarkets');
            renderMarkets(d.commodities, 'commodityMarkets');
        } catch(e) { console.warn('Erro ao carregar mercados:', e); }
    }

    window.openMarketModal = function() {
        document.getElementById('marketModal')?.classList.add('active');
        reloadMarkets();
    };

    document.addEventListener('DOMContentLoaded', reloadMarkets);
    </script>


    <!-- MODAL STOP LOSS -->
    <div id="stopLossModal">
        <div class="stoploss-box">
            <div class="stoploss-header">
                <h3>Opções de stop loss</h3>
                <button onclick="document.getElementById('stopLossModal').classList.remove('active')">×</button>
            </div>
            <div class="stoploss-body">
                <p>Você pode escolher usar o número de perdas em sequência ou o valor de stop loss.</p>
                <label>Tipo de stop loss</label>
                <select class="stoploss-select" id="stopLossType" onchange="applyStopLossType(this.value)">
                    <option value="value">Usar valor de stop loss</option>
                    <option value="sequence">Usar perdas em sequência</option>
                    <option value="both">Usar ambos</option>
                </select>
                <div id="stopLossSequenceGroup" style="display:none;margin-top:16px;">
                    <label>Número de perdas em sequência</label>
                    <div class="input-wrapper" style="margin-top:0;">
                        <input type="number" id="stopLossSequence" value="3" min="1" max="20" step="1" style="background:none;border:none;color:#fff;font-size:15px;width:100%;outline:none;">
                    </div>
                </div>
            </div>
            <div class="stoploss-footer">
                <button onclick="document.getElementById('stopLossModal').classList.remove('active')">FECHAR</button>
            </div>
        </div>
    </div>
    <script>
    function openStopLossModal() {
        document.getElementById('stopLossModal').classList.add('active');
    }
    function applyStopLossType(val) {
        const seqGroup = document.getElementById('stopLossSequenceGroup');
        seqGroup.style.display = (val === 'sequence' || val === 'both') ? 'block' : 'none';
    }
    </script>

</body>
</html>