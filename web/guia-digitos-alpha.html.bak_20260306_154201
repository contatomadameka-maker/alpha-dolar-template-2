<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Alpha Dolar 2.0 — Guia Visual de Dígitos</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@400;700&family=Syne:wght@400;600;700;800&family=Orbitron:wght@700;900&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #0a0c10;
  --panel: #111318;
  --panel2: #13161e;
  --border: #1e2230;
  --blue: #42A5F5;
  --green: #4caf50;
  --red: #f44336;
  --gold: #FFB300;
  --purple: #ba68c8;
  --pink: #d81b60;
  --cyan: #00d2ff;
  --text: #e0e0e0;
  --muted: #555;
}
* { margin:0; padding:0; box-sizing:border-box; }
body { background:var(--bg); color:var(--text); font-family:'Syne',sans-serif; overflow-x:hidden; }

/* ── HERO ── */
.hero {
  text-align:center;
  padding:70px 20px 50px;
  background: radial-gradient(ellipse at 50% -10%, rgba(0,210,255,0.13) 0%, rgba(216,27,96,0.06) 40%, transparent 70%);
  border-bottom:1px solid var(--border);
  position:relative;
  overflow:hidden;
}
.hero::before {
  content:'';
  position:absolute; inset:0;
  background: repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(255,255,255,0.02) 40px),
              repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(255,255,255,0.02) 40px);
  pointer-events:none;
}
.hero-badge {
  display:inline-block;
  background:rgba(0,210,255,0.1);
  border:1px solid rgba(0,210,255,0.3);
  color:var(--cyan);
  font-family:'Space Mono',monospace;
  font-size:11px; letter-spacing:3px;
  padding:6px 18px; border-radius:20px; margin-bottom:22px;
}
.hero h1 { font-size:clamp(28px,5vw,50px); font-weight:800; line-height:1.1; margin-bottom:14px; }
.hero h1 .c1 { color:var(--cyan); }
.hero h1 .c2 { color:var(--pink); }
.hero p { color:#777; font-size:15px; max-width:520px; margin:0 auto; line-height:1.7; }

.win-badge {
  display:inline-flex; align-items:center; gap:10px;
  background:rgba(76,175,80,0.1);
  border:1px solid rgba(76,175,80,0.3);
  border-radius:12px; padding:12px 20px;
  margin:24px auto 0;
  font-family:'Space Mono',monospace; font-size:13px; color:var(--green);
}
.win-dot { width:8px; height:8px; border-radius:50%; background:var(--green); animation:pulse 1.5s infinite; }
@keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(1.6)} }

/* ── NOVO: BANNER MODO IA AVANÇADO ── */
.ia-banner {
  margin: 40px auto 0;
  max-width: 700px;
  background: linear-gradient(135deg, rgba(216,27,96,0.15), rgba(0,210,255,0.08));
  border: 1px solid rgba(216,27,96,0.4);
  border-radius: 16px;
  padding: 20px 24px;
  display: flex; align-items: center; gap: 18px;
  position: relative; overflow: hidden;
}
.ia-banner::before {
  content:'';
  position:absolute; inset:0;
  background: repeating-linear-gradient(45deg, transparent, transparent 8px, rgba(216,27,96,0.03) 8px, rgba(216,27,96,0.03) 9px);
  pointer-events:none;
}
.ia-banner-icon { font-size:36px; flex-shrink:0; }
.ia-banner-text h3 { color:var(--pink); font-size:15px; font-weight:800; margin-bottom:4px; }
.ia-banner-text p { color:#aaa; font-size:13px; line-height:1.6; }
.ia-badge-new {
  background:var(--pink); color:#fff;
  font-family:'Space Mono',monospace; font-size:9px; font-weight:700;
  padding:3px 8px; border-radius:10px; margin-left:8px; letter-spacing:1px;
  animation: badge-pulse 2s infinite;
}
@keyframes badge-pulse { 0%,100%{opacity:1} 50%{opacity:.6} }

/* ── LAYOUT ── */
.section { padding:50px 20px; max-width:980px; margin:0 auto; }
.section-num { font-family:'Space Mono',monospace; font-size:11px; color:var(--cyan); letter-spacing:3px; margin-bottom:8px; }
.section-title { font-size:28px; font-weight:800; margin-bottom:6px; }
.section-sub { color:#666; font-size:14px; margin-bottom:32px; }
.divider { border:none; border-top:1px solid var(--border); margin:0; }

/* ── FLOW ── */
.flow { display:flex; align-items:center; gap:0; flex-wrap:wrap; margin:20px 0; }
.flow-step {
  display:flex; align-items:center; gap:10px;
  background:var(--panel); border:1px solid var(--border);
  border-radius:10px; padding:12px 16px; font-size:13px; flex:1; min-width:130px;
}
.flow-step .fi { font-size:20px; flex-shrink:0; }
.flow-step small { font-size:11px; color:#555; display:block; }
.flow-arrow { color:var(--muted); font-size:20px; padding:0 6px; flex-shrink:0; }

/* ── CARDS PASSO ── */
.step-card { background:var(--panel); border:1px solid var(--border); border-radius:16px; overflow:hidden; margin-bottom:24px; }
.step-header { display:flex; align-items:center; gap:16px; padding:20px 24px; border-bottom:1px solid var(--border); }
.step-num {
  width:36px; height:36px; border-radius:50%;
  background:rgba(0,210,255,0.1); border:1.5px solid var(--cyan);
  display:flex; align-items:center; justify-content:center;
  font-family:'Space Mono',monospace; font-size:14px; font-weight:700; color:var(--cyan); flex-shrink:0;
}
.step-header h3 { font-size:16px; font-weight:700; }
.step-header p { font-size:12px; color:#666; margin-top:2px; }
.step-body { padding:24px; }

/* ── TABELA MULTIMERCADO ── */
.mm-table-demo { width:100%; border-collapse:collapse; font-family:'Space Mono',monospace; font-size:12px; margin-bottom:16px; }
.mm-table-demo th { color:var(--muted); font-size:10px; letter-spacing:1px; padding:8px 10px; text-align:left; border-bottom:1px solid var(--border); }
.mm-table-demo td { padding:10px 10px; border-bottom:1px solid rgba(255,255,255,0.03); }
.mm-bar-row { display:flex; height:12px; border-radius:6px; overflow:hidden; gap:2px; }
.mm-par  { background:rgba(76,175,80,0.7);  border-radius:6px 0 0 6px; display:flex; align-items:center; justify-content:center; font-size:9px; color:#000; font-weight:700; }
.mm-impar{ background:rgba(66,165,245,0.5); border-radius:0 6px 6px 0; display:flex; align-items:center; justify-content:center; font-size:9px; color:#000; font-weight:700; }
.arrow-box { display:flex; align-items:center; gap:12px; background:rgba(76,175,80,0.08); border:1px solid rgba(76,175,80,0.2); border-radius:10px; padding:14px 16px; margin-top:12px; }
.arrow-icon { font-size:24px; flex-shrink:0; }
.arrow-box p { font-size:13px; color:var(--green); font-weight:600; }
.arrow-box small { color:#666; font-size:11px; display:block; margin-top:2px; }

/* ── PILLS ── */
.pills-grid { display:flex; gap:8px; flex-wrap:wrap; margin-bottom:16px; }
.pill-demo { display:flex; flex-direction:column; align-items:center; width:56px; height:64px; border-radius:10px; border:1.5px solid var(--border); background:#13151a; justify-content:center; gap:4px; position:relative; }
.pill-demo .dn { font-family:'Space Mono',monospace; font-size:20px; font-weight:700; }
.pill-demo .dp { font-family:'Space Mono',monospace; font-size:9px; color:#555; }
.pill-demo.hi { border-color:var(--green); background:rgba(76,175,80,0.08); }
.pill-demo.hi .dn { color:var(--green); }
.pill-demo.lo { border-color:var(--red); background:rgba(244,67,54,0.08); }
.pill-demo.lo .dn { color:var(--red); }
.label-over { position:absolute; top:-24px; left:50%; transform:translateX(-50%); font-size:9px; font-weight:700; letter-spacing:1px; white-space:nowrap; }
.label-over.green { color:var(--green); }
.label-over.red { color:var(--red); }
.pills-wrapper { position:relative; padding-top:28px; margin-bottom:8px; }

/* ── OSC ── */
.osc-demo { background:#0d0f14; border:1px solid var(--border); border-radius:10px; padding:16px; margin-bottom:16px; }
.chart-svg { width:100%; height:80px; }

/* ── CENÁRIOS ── */
.scenario-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(290px,1fr)); gap:16px; }
.scenario-card { background:var(--panel); border:1px solid var(--border); border-radius:14px; overflow:hidden; transition:border-color .2s, transform .2s; }
.scenario-card:hover { border-color:#2a3050; transform:translateY(-2px); }
.scenario-top { padding:16px; border-bottom:1px solid var(--border); }
.scenario-tag { display:inline-block; font-family:'Space Mono',monospace; font-size:9px; letter-spacing:2px; padding:3px 10px; border-radius:20px; margin-bottom:10px; font-weight:700; }
.tag-bull   { background:rgba(76,175,80,0.15); color:var(--green); border:1px solid rgba(76,175,80,0.3); }
.tag-bear   { background:rgba(244,67,54,0.15); color:var(--red); border:1px solid rgba(244,67,54,0.3); }
.tag-seq    { background:rgba(255,179,0,0.15); color:var(--gold); border:1px solid rgba(255,179,0,0.3); }
.tag-quiet  { background:rgba(186,104,200,0.15); color:var(--purple); border:1px solid rgba(186,104,200,0.3); }
.tag-pulse  { background:rgba(66,165,245,0.15); color:var(--blue); border:1px solid rgba(66,165,245,0.3); }
.tag-skew   { background:rgba(77,208,225,0.15); color:#4dd0e1; border:1px solid rgba(77,208,225,0.3); }
.tag-ia     { background:rgba(216,27,96,0.15); color:var(--pink); border:1px solid rgba(216,27,96,0.4); }
.scenario-title { font-size:15px; font-weight:700; margin-bottom:6px; }
.scenario-desc  { font-size:12px; color:#666; line-height:1.5; }
.scenario-chart { padding:12px 16px; border-bottom:1px solid var(--border); background:#0d0f14; }
.scenario-bots  { padding:14px 16px; }
.bots-label { font-size:10px; letter-spacing:1.5px; color:var(--muted); margin-bottom:10px; font-weight:700; }
.bot-chips { display:flex; flex-wrap:wrap; gap:6px; }
.bot-chip { font-family:'Space Mono',monospace; font-size:10px; padding:4px 10px; border-radius:20px; font-weight:700; }
.chip-free    { background:rgba(66,165,245,0.1); color:var(--blue); border:1px solid rgba(66,165,245,0.3); }
.chip-vip     { background:rgba(76,175,80,0.1); color:var(--green); border:1px solid rgba(76,175,80,0.3); }
.chip-premium { background:rgba(255,179,0,0.1); color:var(--gold); border:1px solid rgba(255,179,0,0.3); }
.chip-ia      { background:rgba(216,27,96,0.15); color:var(--pink); border:1px solid rgba(216,27,96,0.4); }

/* ── BANCA TABLE ── */
.banca-table { width:100%; border-collapse:collapse; }
.banca-table th { background:#0d0f14; padding:12px 16px; text-align:left; font-size:11px; letter-spacing:1px; color:var(--muted); border-bottom:1px solid var(--border); }
.banca-table td { padding:14px 16px; border-bottom:1px solid rgba(255,255,255,0.04); font-size:13px; }
.banca-table tr:last-child td { border-bottom:none; }
.tier-free    { color:var(--blue); font-weight:700; }
.tier-vip     { color:var(--green); font-weight:700; }
.tier-premium { color:var(--gold); font-weight:700; }

/* ── HIGHLIGHT BOX ── */
.highlight-box { background:rgba(66,165,245,0.06); border:1px solid rgba(66,165,245,0.2); border-radius:12px; padding:18px 20px; margin-top:16px; font-size:13px; line-height:1.7; color:#aaa; }
.highlight-box strong { color:var(--blue); }
.highlight-box.green { background:rgba(76,175,80,0.06); border-color:rgba(76,175,80,0.2); }
.highlight-box.green strong { color:var(--green); }
.highlight-box.pink  { background:rgba(216,27,96,0.06); border-color:rgba(216,27,96,0.3); }
.highlight-box.pink  strong { color:var(--pink); }

/* ── TICKER ── */
.tb { flex-shrink:0; width:32px; height:32px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-family:'Space Mono',monospace; font-size:13px; font-weight:700; background:#13151a; border:1.5px solid #2a2d35; }

/* ── NOVA SEÇÃO: MODO IA AVANÇADO ── */
.ia-section {
  background: linear-gradient(180deg, rgba(216,27,96,0.05) 0%, transparent 100%);
  border-top:1px solid rgba(216,27,96,0.2);
  border-bottom:1px solid rgba(216,27,96,0.2);
  padding:50px 20px;
}
.ia-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(280px,1fr)); gap:16px; margin-top:24px; }
.ia-card {
  background:var(--panel2);
  border:1px solid rgba(216,27,96,0.25);
  border-radius:14px; padding:20px;
  transition: border-color .2s, transform .2s;
}
.ia-card:hover { border-color:rgba(216,27,96,0.5); transform:translateY(-2px); }
.ia-card-icon { font-size:28px; margin-bottom:10px; }
.ia-card h4 { font-size:14px; font-weight:700; margin-bottom:6px; color:var(--pink); }
.ia-card p { font-size:12px; color:#777; line-height:1.6; }

/* score strip visual */
.score-strip {
  display:flex; gap:8px; flex-wrap:wrap; margin:20px 0 8px;
}
.score-chip {
  flex:1; min-width:90px;
  border-radius:10px; padding:10px 12px;
  font-family:'Space Mono',monospace;
}
.score-chip .sc-label { font-size:9px; letter-spacing:1px; margin-bottom:4px; opacity:.7; }
.score-chip .sc-val   { font-size:16px; font-weight:700; }

/* virtual dots */
.vdots { display:flex; gap:6px; align-items:center; margin:12px 0; }
.vdot {
  width:28px; height:28px; border-radius:50%;
  display:flex; align-items:center; justify-content:center;
  font-size:11px; font-weight:700; font-family:'Space Mono',monospace;
  border:1.5px solid var(--border); color:#555;
}
.vdot.done { background:rgba(244,67,54,0.2); border-color:var(--red); color:var(--red); }
.vdot.real { background:rgba(0,210,255,0.2); border-color:var(--cyan); color:var(--cyan); animation:pulse 1s infinite; }

/* ── NOVA SEÇÃO: MODAL MATRIX ── */
.matrix-section { padding:50px 20px; max-width:980px; margin:0 auto; }
.matrix-preview {
  background: #0a0c10;
  border:1px solid rgba(0,210,255,0.25);
  border-radius:20px;
  overflow:hidden;
  position:relative;
}
.matrix-header {
  background: linear-gradient(90deg, rgba(0,210,255,0.1), rgba(216,27,96,0.1));
  border-bottom:1px solid rgba(0,210,255,0.15);
  padding:14px 20px;
  display:flex; align-items:center; gap:12px;
}
.matrix-dot { width:10px; height:10px; border-radius:50%; }
.matrix-title { font-family:'Orbitron',sans-serif; font-size:13px; font-weight:700; color:var(--cyan); letter-spacing:2px; }
.matrix-body { display:grid; grid-template-columns:1fr 1fr; gap:0; min-height:260px; }
.matrix-left { padding:20px; border-right:1px solid rgba(255,255,255,0.05); }
.matrix-right { padding:20px; }
.pnl-display { text-align:center; margin-bottom:16px; }
.pnl-label { font-size:10px; letter-spacing:2px; color:#555; font-family:'Space Mono',monospace; margin-bottom:4px; }
.pnl-value { font-family:'Orbitron',sans-serif; font-size:28px; font-weight:900; color:var(--green); }
.tradebar { display:flex; gap:4px; height:8px; border-radius:4px; overflow:hidden; margin:12px 0; }
.tbar { flex:1; border-radius:4px; height:100%; }
.tbar.signal { background:var(--cyan); }
.tbar.buy    { background:var(--gold); }
.tbar.win    { background:var(--green); }
.feed-line { font-family:'Space Mono',monospace; font-size:10px; padding:4px 0; border-bottom:1px solid rgba(255,255,255,0.04); display:flex; gap:8px; align-items:center; }
.feed-win  { color:var(--green); }
.feed-loss { color:var(--red); }
.feed-info { color:#555; }
.feed-tag { font-size:9px; padding:1px 6px; border-radius:10px; }
.feed-tag.w { background:rgba(76,175,80,0.2); color:var(--green); }
.feed-tag.l { background:rgba(244,67,54,0.2); color:var(--red); }
.matrix-btn {
  display:inline-flex; align-items:center; gap:8px;
  background: linear-gradient(135deg, var(--pink), #c2185b);
  color:#fff; border:none; border-radius:10px;
  padding:10px 18px; font-size:13px; font-weight:700;
  cursor:pointer; width:100%; justify-content:center;
  margin-top:12px; font-family:'Syne',sans-serif;
  box-shadow: 0 4px 20px rgba(216,27,96,0.4);
  animation: btn-glow 2s infinite;
}
@keyframes btn-glow { 0%,100%{box-shadow:0 4px 20px rgba(216,27,96,0.4)} 50%{box-shadow:0 4px 30px rgba(216,27,96,0.7)} }

/* ── SEGURANÇA ── */
.safety-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(220px,1fr)); gap:14px; margin-top:24px; }
.safety-card {
  background:var(--panel2);
  border:1px solid rgba(76,175,80,0.2);
  border-radius:12px; padding:18px;
}
.safety-card .si { font-size:26px; margin-bottom:8px; }
.safety-card h4 { font-size:13px; font-weight:700; color:var(--green); margin-bottom:4px; }
.safety-card p  { font-size:11px; color:#666; line-height:1.6; }

/* ── TICKER ── */
@keyframes ticker-scroll { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }

/* ── FOOTER ── */
.footer { text-align:center; padding:40px 20px; border-top:1px solid var(--border); color:#444; font-family:'Space Mono',monospace; font-size:11px; letter-spacing:2px; }
</style>
</head>
